# ---------------------------------------------------------------------------
# Central secrets file.  Copy to `.env` and fill in.  `.env` is git-ignored and
# NEVER committed.  On a vast box: place it at /workspace/.env (bootstrap sources
# it).  Everything secret is read from here; everything non-secret lives in
# configs/experiment.yaml.
# ---------------------------------------------------------------------------

# HuggingFace token (read).  Needs: gated ImageNet-1k access accepted, and
# write access to your private dataset repo (hf.dataset_repo in experiment.yaml).
export HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub fine-grained PAT.  Needs: Contents Read/Write on the code repo
# (used to push results to the `results` branch).
export GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Vast.ai API key.  ONLY needed on your laptop for the destroy-watcher.
# Do NOT put this on the rented box.  (Leave unset on the box.)
export VAST_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
